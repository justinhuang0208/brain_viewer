        "height": 158,
        "fileSize": 9020,
        "url": "https://api.worldquantbrain.com/content/images/8VUjMZnI7iWVTp8VD_J1DfnBahI=/27/original/OLS_Rettype_List.PNG"
      },
      "id": "40690855-aafd-4a20-a5b7-fe1167c08ea1"
    },
